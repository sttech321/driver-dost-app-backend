// Driver Dost — Prisma schema (PostgreSQL)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────── Enums ─────────────────────────
enum UserRole {
  USER
  DRIVER
}

enum AuthProvider {
  PHONE
  GOOGLE
  PASSWORD
}

enum BookingType {
  ONE_WAY
  HOURLY
  ROUND_TRIP
  OUTSTATION
}

enum OutstationTripType {
  ROUND_TRIP
  ONE_WAY
}

enum BookingStatus {
  REQUESTED
  ACCEPTED
  ARRIVING
  ONGOING
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CREDIT_CARD
  UPI
  CASH
  WALLET
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum ChatSenderType {
  USER
  DRIVER
}

enum WalletTopUpStatus {
  PENDING
  PAID
  FAILED
}

enum NotificationType {
  BOOKING_ACCEPTED
  DRIVER_ARRIVING
  RIDE_STARTED
  RIDE_COMPLETED
  RIDE_CANCELLED
  PAYMENT_SUCCESS
  WALLET_CREDITED
  CHAT_MESSAGE
  NEW_REQUEST
  PROMO
  GENERAL
}

// ───────────────────────── Models ────────────────────────
model User {
  id          String        @id @default(uuid())
  firebaseUid String?       @unique
  phone       String?       @unique
  email       String?       @unique
  name        String?
  photoUrl    String?
  role        UserRole      @default(USER)
  provider    AuthProvider  @default(PHONE)
  // Only set when the user registers with phone + password (Register/Login form).
  passwordHash String?
  walletBalance Decimal      @default(0) @db.Decimal(10, 2)
  isPhoneVerified Boolean    @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  savedPlaces SavedPlace[]
  bookings    Booking[]
  reviews     Review[]
  walletTopUps WalletTopUp[]
  notifications Notification[]
  // A DRIVER account links to exactly one Driver profile.
  driverProfile Driver?

  @@map("users")
}

model Driver {
  id          String    @id @default(uuid())
  // Linked account for drivers who registered & log in (null for seed-only demo drivers).
  userId      String?   @unique
  code        String    @unique // e.g. DDO023
  name        String
  title       String    @default("Master Driver")
  photoUrl    String?
  phone       String?
  rating      Decimal   @default(0) @db.Decimal(2, 1)
  ratingCount Int       @default(0)
  isVerified  Boolean   @default(true)
  isAvailable Boolean   @default(true)
  // Last known position — powers "Recommended Drivers" near a user.
  lat         Float?
  lng         Float?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  bookings    Booking[]
  reviews     Review[]

  @@map("drivers")
}

model SavedPlace {
  id          String   @id @default(uuid())
  userId      String
  label       String   // e.g. "Finvasia", "SBP"
  addressLine String   // e.g. "Sector 174"
  lat         Float?
  lng         Float?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("saved_places")
}

model Booking {
  id              String              @id @default(uuid())
  userId          String
  driverId        String?
  type            BookingType
  status          BookingStatus       @default(REQUESTED)

  // Pickup
  pickupLabel     String?
  pickupAddress   String?
  pickupLat       Float?
  pickupLng       Float?

  // Destination (not required for HOURLY)
  destinationLabel   String?
  destinationAddress String?
  destinationLat     Float?
  destinationLng     Float?

  // Scheduling
  scheduledAt     DateTime?
  // HOURLY: start/end hour of day + total hours
  startHour       Int?
  endHour         Int?
  hours           Int?
  // OUTSTATION trip sub-type & its fixed price tier
  outstationType  OutstationTripType?

  distanceKm      Float?
  etaMinutes      Int?
  amount          Decimal             @default(0) @db.Decimal(10, 2)

  paymentMethod   PaymentMethod?
  paymentStatus   PaymentStatus       @default(PENDING)
  // Gateway references for online (Card/UPI) payments.
  paymentOrderId  String?
  paymentRef      String?

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  driver          Driver?             @relation(fields: [driverId], references: [id])
  messages        ChatMessage[]
  review          Review?

  @@index([userId])
  @@index([driverId])
  @@map("bookings")
}

model ChatMessage {
  id         String         @id @default(uuid())
  bookingId  String
  senderType ChatSenderType
  text       String
  createdAt  DateTime       @default(now())

  booking    Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("chat_messages")
}

// One rider review per booking; drives the driver's aggregate rating.
model Review {
  id        String   @id @default(uuid())
  bookingId String   @unique
  driverId  String
  userId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  driver  Driver  @relation(fields: [driverId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([driverId])
  @@map("reviews")
}

// Ledger for "Add Money to Wallet" via the payment gateway. One row per attempt;
// orderId is unique so a verified top-up is credited exactly once (idempotent).
model WalletTopUp {
  id           String            @id @default(uuid())
  userId       String
  orderId      String            @unique
  paymentId    String?
  packageId    String? // null for a manual/custom amount
  amount       Decimal           @db.Decimal(10, 2) // what the user pays (gateway)
  bonusAmount  Decimal           @default(0) @db.Decimal(10, 2)
  creditAmount Decimal           @default(0) @db.Decimal(10, 2) // amount + bonus → credited to wallet
  status       WalletTopUpStatus @default(PENDING)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("wallet_topups")
}

// In-app notifications (bell icon). Persisted so the list + unread count survive
// restarts; delivered live via Socket.IO ("notification:new") to the user's room.
model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  // Deep-link payload, e.g. { "bookingId": "...", "peerName": "..." }.
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

// Fallback OTP store — used only when Firebase phone auth is not configured.
model OtpCode {
  id        String   @id @default(uuid())
  phone     String
  codeHash  String
  expiresAt DateTime
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
  @@map("otp_codes")
}
