# ── Server ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed origins for CORS (Expo dev, etc.)
CORS_ORIGINS=*

# ── Database (PostgreSQL) ───────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/driver_dost?schema=public

# ── JSON Web Token (our own session tokens) ─────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=30d

# ── Firebase Admin (verifies phone-OTP & Google ID tokens) ─
# From Firebase console → Project settings → Service accounts → Generate new private key.
# Either point to a JSON file OR inline the 3 fields below.
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── OTP delivery ────────────────────────────────────────
OTP_TTL_SECONDS=300
# Log the generated code to the server console (handy in dev).
OTP_DEV_LOG=true

# To send OTP as a REAL SMS, configure ONE provider below.
# With none set, the code is only logged (dev fallback).

# Twilio (global). console.twilio.com → Account SID, Auth Token, a Twilio number.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=+1xxxxxxxxxx

# Fast2SMS (India). fast2sms.com → Dev API key.
# FAST2SMS_API_KEY=

# Default country code used to normalise 10-digit numbers (India = 91).
SMS_DEFAULT_COUNTRY_CODE=91

# ── Payments (Card / UPI via Razorpay) ──────────────────
# dashboard.razorpay.com → Settings → API Keys → Generate.
# Without these, online (Card/UPI) payments run in DEV-MOCK mode (no real charge).
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# ── Geocoding (address autocomplete + reverse for the map picker) ─
# Free, keyless OpenStreetMap-based providers. "photon" is best for typeahead.
# Options: photon | nominatim
GEOCODER_PROVIDER=photon
