# ── Server ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed origins for CORS (Expo dev, etc.)
CORS_ORIGINS=*

# ── Database (PostgreSQL) ───────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/driver_dost?schema=public

# ── JSON Web Token (our own session tokens) ─────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=30d

# ── Firebase Admin (verifies phone-OTP & Google ID tokens) ─
# From Firebase console → Project settings → Service accounts → Generate new private key.
# Either point to a JSON file OR inline the 3 fields below.
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── OTP fallback (used only if Firebase is not configured) ─
# In dev, generated OTPs are logged to the console instead of sent via SMS.
OTP_TTL_SECONDS=300
OTP_DEV_LOG=true

# ── Geocoding (address autocomplete + reverse for the map picker) ─
# Free, keyless OpenStreetMap-based providers. "photon" is best for typeahead.
# Options: photon | nominatim
GEOCODER_PROVIDER=photon
